                                <button type="button" data-bs-target="#cityCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Bogaz Koprusu"></button>
                                <button type="button" data-bs-target="#cityCarousel" data-bs-slide-to="1" aria-label="Vapur"></button>
                                <button type="button" data-bs-target="#cityCarousel" data-bs-slide-to="2" aria-label="Galata"></button>
