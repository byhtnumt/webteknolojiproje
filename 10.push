                                <?php endforeach; ?>
                            </ul>
                        </div>
                        <?php else: ?>
                        <div class="feedback-box success mb-4" role="status">
                            Form başarıyla doğrulandı ve sunucu tarafında kabul edildi.
                        </div>
                        <?php endif; ?>

                                <h2 class="mb-3">Gönderilen Tüm Bilgiler</h2>
                                <div class="table-responsive result-table-shell">
                                    <table class="table align-middle result-table mb-0">
