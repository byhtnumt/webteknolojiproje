<?php
if ($_SERVER["REQUEST_METHOD"] !== "POST") {
    header("Location: iletisim.html");
    exit;
}

function h($value)
{
    return htmlspecialchars((string) $value, ENT_QUOTES, "UTF-8");
}

function normalizeTextValue($value)
{
    $value = strip_tags((string) $value);
    $value = preg_replace('/\s+/u', ' ', $value);
    return trim((string) $value);
}

function normalizeEmailValue($value)
{
    $value = strip_tags((string) $value);
    $value = preg_replace('/\s+/', '', $value);
    return strtolower(trim((string) $value));
}

function normalizePhoneValue($value)
{
    $digits = preg_replace('/\D+/', '', strip_tags((string) $value));
    return substr((string) $digits, 0, 11);
}

function stringLength($value)
{
    return function_exists("mb_strlen") ? mb_strlen((string) $value, "UTF-8") : strlen((string) $value);
}

function displayValue($value, $fallback = "Girilmedi")
{
    $trimmedValue = trim((string) $value);
    return $trimmedValue !== "" ? $trimmedValue : $fallback;
}

function formatDateValue($value)
{
    $trimmedValue = trim((string) $value);

    if ($trimmedValue === "") {
        return "Secilmedi";
    }

    $timestamp = strtotime($trimmedValue);
    return $timestamp ? date("d.m.Y", $timestamp) : $trimmedValue;
}

function parseSubmittedDate($value)
{
    $trimmedValue = trim((string) $value);

    if ($trimmedValue === "") {
        return null;
    }

    $date = DateTimeImmutable::createFromFormat("Y-m-d", $trimmedValue);
    if (!$date || $date->format("Y-m-d") !== $trimmedValue) {
        return null;
    }

    return $date;
}

$allowedTopics = [
    "Sitede hatali bilgi var",
    "Sitede telif kurallarina uymayan gorsel var",
    "Diger",
];
$allowedEducation = [
    "Ilkokul",
    "Ortaokul",
    "Lise",
    "Universite",
];
$allowedJobs = [
    "Muzisyenlik",
    "Fotografcilik",
    "Diger",
];
$allowedEducationOptions = [
    "Ilkokul",
    "Ortaokul",
    "Lise",
    "Universite",
];
$namePattern = "/^[\\p{L}\\s'-]{2,50}$/u";
$emailPattern = '/^[^\s@]+@(?:gmail\.com|(?:[a-z0-9-]+\.)*edu\.tr)$/i';
$phonePattern = '/^[0-9]{10,11}$/';

$ad = normalizeTextValue($_POST["ad"] ?? "");
$soyad = normalizeTextValue($_POST["soyad"] ?? "");
$email = normalizeEmailValue($_POST["email"] ?? "");
$telefon = normalizePhoneValue($_POST["telefon"] ?? "");
$dogumTarihi = trim($_POST["dogum_tarihi"] ?? "");
$konu = normalizeTextValue($_POST["konu"] ?? "");
$egitim = normalizeTextValue($_POST["egitim"] ?? "");
$mesaj = trim(strip_tags((string) ($_POST["mesaj"] ?? "")));
$meslek = normalizeTextValue($_POST["meslek"] ?? "");
$validationSource = normalizeTextValue($_POST["validation_source"] ?? "Belirtilmedi");
$egitimSecenekleri = $_POST["egitim_secenekleri"] ?? [];
$kvkk = isset($_POST["kvkk"]) ? "Onaylandi" : "Onaylanmadi";

if (!is_array($egitimSecenekleri)) {
    $egitimSecenekleri = [$egitimSecenekleri];
}

$egitimSecenekleri = array_values(array_filter(array_map("trim", $egitimSecenekleri), function ($value) {
    return $value !== "";
}));
$egitimSecenekleri = array_values(array_unique($egitimSecenekleri));

$validationErrors = [];
$dogumTarihiDate = parseSubmittedDate($dogumTarihi);
$today = new DateTimeImmutable("today");

if ($ad === "") {
    $validationErrors[] = "Ad alani bos birakilamaz.";
} elseif (!preg_match($namePattern, $ad)) {
    $validationErrors[] = "Ad alani sadece harf, bosluk, kesme isareti ve tire icerebilir.";
}

if ($soyad === "") {
    $validationErrors[] = "Soyad alani bos birakilamaz.";
} elseif (!preg_match($namePattern, $soyad)) {
    $validationErrors[] = "Soyad alani sadece harf, bosluk, kesme isareti ve tire icerebilir.";
}

if ($email === "" || !preg_match($emailPattern, $email)) {
    $validationErrors[] = "E-posta alani sadece gmail.com veya edu.tr uzantili adres kabul eder.";
}

if ($telefon === "" || !preg_match($phonePattern, $telefon)) {
    $validationErrors[] = "Telefon numarasi sadece rakamlardan olusmali ve 10 ya da 11 hane olmali.";
}

if ($dogumTarihi === "") {
    $validationErrors[] = "Dogum tarihi seciniz.";
} elseif (!$dogumTarihiDate) {
    $validationErrors[] = "Gecerli bir dogum tarihi seciniz.";
} elseif ($dogumTarihiDate > $today) {
    $validationErrors[] = "Dogum tarihi bugunden ileri bir tarih olamaz.";
}

if ($konu === "" || !in_array($konu, $allowedTopics, true)) {
    $validationErrors[] = "Listeden gecerli bir konu seciniz.";
}

if ($egitim === "" || !in_array($egitim, $allowedEducation, true)) {
    $validationErrors[] = "Listeden gecerli bir egitim seviyesi seciniz.";
}

if ($meslek === "" || !in_array($meslek, $allowedJobs, true)) {
    $validationErrors[] = "Gecerli bir meslek tercihi yapiniz.";
}

if (count($egitimSecenekleri) === 0) {
    $validationErrors[] = "En az bir egitim secenegi seciniz.";
} elseif (count(array_diff($egitimSecenekleri, $allowedEducationOptions)) > 0) {
    $validationErrors[] = "Egitim seceneklerinde gecersiz bir tercih var.";
}

if ($mesaj === "" || stringLength($mesaj) < 20) {
    $validationErrors[] = "Mesaj alani en az 20 karakter olmali.";
} elseif (stringLength($mesaj) > 1000) {
    $validationErrors[] = "Mesaj alani en fazla 1000 karakter olabilir.";
}

if (!isset($_POST["kvkk"])) {
    $validationErrors[] = "Acik riza kutusunu isaretlemeniz gerekiyor.";
}

$hasErrors = count($validationErrors) > 0;

if ($hasErrors) {
    http_response_code(422);
}

$tumAlanlar = [
    ["label" => "Ad", "value" => displayValue($ad)],
    ["label" => "Soyad", "value" => displayValue($soyad)],
    ["label" => "E-posta", "value" => displayValue($email)],
    ["label" => "Telefon", "value" => displayValue($telefon)],
    ["label" => "Dogum Tarihi", "value" => formatDateValue($dogumTarihi)],
    ["label" => "Konu", "value" => displayValue($konu, "Secilmedi")],
    ["label" => "Egitim", "value" => displayValue($egitim, "Secilmedi")],
    ["label" => "Meslek", "value" => displayValue($meslek, "Secilmedi")],
    ["label" => "Egitim Secenekleri", "value" => count($egitimSecenekleri) > 0 ? implode(", ", $egitimSecenekleri) : "Secim yapilmamis"],
    ["label" => "Mesaj", "value" => displayValue($mesaj)],
    ["label" => "KVKK", "value" => $kvkk],
    ["label" => "Dogrulama Yontemi", "value" => displayValue($validationSource, "Belirtilmedi")],
];
?>
